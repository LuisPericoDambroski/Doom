# =============================================
# DESENVOLVIMENTO LOCAL (Docker PostgreSQL)
# =============================================
# Copie este arquivo para .env e ajuste conforme necessário:
#   cp .env.example .env

# Conexão local (Docker Compose)
# Usuário, senha e banco devem corresponder ao docker-compose.yml
DATABASE_URL="postgresql://doom:doom_dev_password@localhost:5432/doom_dev"

# Fallback para Neon (usado em produção / deploy Manus)
# NEON_DATABASE_URL="postgresql://..."

# Configurações de autenticação e segurança
JWT_SECRET="doom_secret_key_dev"
VITE_APP_ID="loginsite-cseggtqx"

# Ambiente (development em local, production em deploy)
NODE_ENV="development"
